# Banco de dados — Local (Docker)
DB_NAME=wordpress
DB_USER=wordpress
DB_PASSWORD=wordpress
DB_HOST=db
DB_TABLE_PREFIX=wp_

# Hostinger: substitua pelos dados do hPanel → Databases → Management
# DB_NAME=u123456789_seu_banco
# DB_USER=u123456789_seu_usuario
# DB_PASSWORD=sua_senha_mysql
# DB_HOST=localhost

# URL canônica do site (Google Search — sem www)
# GURU_CANONICAL_HOST=gurudodesconto.com.br
# No wp-config.php (produção), use:
# define('WP_HOME', 'https://gurudodesconto.com.br');
# define('WP_SITEURL', 'https://gurudodesconto.com.br');

# Meta Pixel (PixelYourSite + fallback do tema — também em Aparência → Personalizar)
GURU_META_PIXEL_ID=1757914428796151

# Microsoft Clarity (heatmaps / gravações — também em Aparência → Personalizar)
GURU_CLARITY_ID=xkd09nsyqn
