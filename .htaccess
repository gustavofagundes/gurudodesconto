# BEGIN Guru Security
<IfModule mod_rewrite.c>
RewriteEngine On

# Canonical 301: HTTP e www → https://gurudodesconto.com.br (Google Search)
RewriteCond %{HTTP_HOST} ^(?:www\.)?gurudodesconto\.com\.br$ [NC]
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} ^www\.gurudodesconto\.com\.br$ [NC]
RewriteRule ^ https://gurudodesconto.com.br%{REQUEST_URI} [R=301,L,NE]

# URL canônica dos grupos WhatsApp (plural)
RewriteRule ^grupo-whatsapp/?$ /grupos-whatsapp/ [R=301,L]
RewriteRule ^grupo-whatsapp/(.*)$ /grupos-whatsapp/$1 [R=301,L]

# Bloqueia acesso direto a arquivos sensíveis
RewriteRule ^\.env - [F,L]
RewriteRule ^wp-config\.php - [F,L]
RewriteRule ^\.git - [F,L]

# Bloqueia XML-RPC (ataques brute force)
RewriteRule ^xmlrpc\.php - [F,L]
</IfModule>

<FilesMatch "^(\.env|wp-config\.php|\.htaccess|\.gitignore)$">
	Require all denied
</FilesMatch>

<IfModule mod_headers.c>
	Header set X-Content-Type-Options "nosniff"
	Header set X-Frame-Options "SAMEORIGIN"
	Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Cache de assets estáticos (imagens, CSS, JS do tema)
<IfModule mod_expires.c>
	ExpiresActive On
	ExpiresByType image/png "access plus 1 year"
	ExpiresByType image/jpeg "access plus 1 year"
	ExpiresByType image/webp "access plus 1 year"
	ExpiresByType image/svg+xml "access plus 1 year"
	ExpiresByType text/css "access plus 1 year"
	ExpiresByType application/javascript "access plus 1 year"
	ExpiresByType font/woff2 "access plus 1 year"
</IfModule>
<IfModule mod_headers.c>
	<FilesMatch "\.(png|jpe?g|webp|svg|css|js|woff2)$">
		Header set Cache-Control "public, max-age=31536000, immutable"
	</FilesMatch>
</IfModule>
# END Guru Security

# BEGIN WordPress
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
RewriteBase /
RewriteRule ^index\.php$ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.php [L]
</IfModule>
# END WordPress
